ANTHROPIC_API_KEY=your-key-here

# Encryption-at-rest for Temporal payloads (event history). When set, the worker
# and server encrypt every payload with AES-256-GCM before it reaches the server.
# Generate a key:  python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=your-base64-32-byte-key

